<Project Sdk="Microsoft.NET.Sdk.WebAssembly">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <OverrideHtmlAssetPlaceholders>true</OverrideHtmlAssetPlaceholders>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Critical: do NOT trim TypeForwardedTo metadata; do NOT trim reflection.
         SDV relies on reflection at runtime. -->
    <TrimMode>partial</TrimMode>
    <!-- Inline the boot config into dotnet.js so we don't need a separate
         dotnet.boot.js file (which the SDK does NOT generate by default
         in Microsoft.NET.Sdk.WebAssembly). -->
    <WasmInlineBootConfig>true</WasmInlineBootConfig>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\MonoGame.Framework.Facade\MonoGame.Framework.Facade.csproj" />
  </ItemGroup>

  <!-- Prevent the trimmer from removing the MonoGame.Framework facade AND
       the KNI assemblies that the facade forwards to.

       The facade has no types of its own (only [assembly: TypeForwardedTo]
       attributes), so the trimmer sees its KNI PackageReferences as "unused"
       and strips them — which breaks TypeForwardedTo resolution at runtime.
       Adding TrimmerRootAssembly for each KNI assembly forces the trimmer
       to keep them in the bundle. -->
  <ItemGroup>
    <TrimmerRootAssembly Include="MonoGame.Framework" />
    <TrimmerRootAssembly Include="Xna.Framework" />
    <TrimmerRootAssembly Include="Xna.Framework.Game" />
    <TrimmerRootAssembly Include="Xna.Framework.Graphics" />
    <TrimmerRootAssembly Include="Xna.Framework.Content" />
    <TrimmerRootAssembly Include="Xna.Framework.Input" />
  </ItemGroup>

  <!-- User-supplied SDV DLL — gitignored, copied to wwwroot at build time if present -->
  <ItemGroup>
    <None Include="Stardew Valley.dll" CopyToOutputDirectory="PreserveNewest" Condition="Exists('Stardew Valley.dll')" />
  </ItemGroup>
</Project>
